{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "MFA Tool",
  "version": "0.3.3",
  "identifier": "com.mfa-tool.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:19872",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "MFA Tool",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFCM0ZEQzc1QzlBRTJGQjYKUldTMkw2N0pkZHcvRzM3TFBTS2tsNXdvTTlNenpKZngxOGljOVY5RkMrYVZ2d203cnZuMWRLL3UK",
      "endpoints": [
        "https://github.com/CovoebGem/MFA-Tool/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
